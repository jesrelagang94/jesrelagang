# Security Headers for Netlify/Vercel/Static Hosting
# Last updated: Security hardening
# Test at: https://securityheaders.com

/*
  # Prevent clickjacking attacks
  X-Frame-Options: DENY

  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Enable XSS protection (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Control referrer information
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser features and APIs
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), autoplay=(), encrypted-media=(self), fullscreen=(self), picture-in-picture=(self)

  # Content Security Policy - Production hardened for Vue 3 + Firebase
  # Note: 'unsafe-inline' required for Vue styles, 'unsafe-eval' removed where possible
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com https://maps.googleapis.com https://maps.google.com https://www.google-analytics.com https://www.googletagmanager.com https://*.firebaseapp.com https://*.firebase.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://maps.googleapis.com https://*.googleapis.com https://*.firebaseio.com https://*.firebase.com https://*.firebaseapp.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.google-analytics.com https://ipapi.co https://api.emailjs.com wss://*.firebaseio.com; frame-src 'self' https://www.google.com https://maps.google.com https://*.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;

  # Strict Transport Security (HTTPS only) - Enable for production
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cross-Origin policies for enhanced security
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Resource-Policy: same-origin

  # Prevent DNS prefetching leaks
  X-DNS-Prefetch-Control: off

  # Disable client-side caching for HTML (security-sensitive)
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Static assets can be cached
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# API endpoints (if applicable)
/api/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Cache-Control: no-store, max-age=0
  Content-Type: application/json

# Admin routes - extra security
/admin/*
  Cache-Control: no-cache, no-store, must-revalidate, private
  Pragma: no-cache
  Expires: 0
  X-Robots-Tag: noindex, nofollow
