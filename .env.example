# =================================================
# JESREL AGANG PORTFOLIO - Environment Configuration
# =================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =================================================

# -------------------------------------------------
# Firebase Configuration
# Get these from Firebase Console > Project Settings
# -------------------------------------------------
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -------------------------------------------------
# EmailJS Configuration (for visitor notifications)
# Get these from https://www.emailjs.com/
# -------------------------------------------------
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# -------------------------------------------------
# Admin Configuration
# Comma-separated list of admin email addresses
# These emails will have access to the admin dashboard
# -------------------------------------------------
VITE_ADMIN_EMAILS=admin@example.com,admin2@example.com

# -------------------------------------------------
# Firebase App Check (reCAPTCHA v3)
# Get from: https://console.cloud.google.com/security/recaptcha
# Required for production bot/abuse protection
# -------------------------------------------------
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# -------------------------------------------------
# Application Settings
# -------------------------------------------------
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# -------------------------------------------------
# Security Notes
# -------------------------------------------------
# 1. Never expose these values in client-side code logs
# 2. Use different values for development and production
# 3. Rotate API keys periodically
# 4. Enable Firebase App Check for additional protection
# 5. Configure Firebase Security Rules properly
